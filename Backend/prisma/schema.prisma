generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  TRAINEE
  TRAINER
  ADMIN
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum TransactionType {
  CREDIT_PURCHASE
  PROGRAM_PURCHASE
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ProgramStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ChallengeStatus {
  PENDING
  PASSED
  FAILED
}

// ─── Auth & Identity ─────────────────────────────────────────────────────────

model User {
  id              Int              @id @default(autoincrement())
  email           String           @unique @db.VarChar(255)
  passwordHash    String           @map("password_hash")
  role            Role             @default(TRAINEE)
  aiCredits       Int              @default(2) @map("ai_credits")
  name            String?          @db.VarChar(255)
  avatarUrl       String?          @map("avatar_url")
  experienceLevel ExperienceLevel? @map("experience_level")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  refreshTokens     RefreshToken[]
  sessions          TrainingSession[]
  transactions      Transaction[]
  exercises         Exercise[]
  programs          TrainingProgram[]
  userPrograms      UserProgram[]
  challengeSessions ChallengeSession[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Transaction {
  id          Int             @id @default(autoincrement())
  userId      Int             @map("user_id")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType @default(CREDIT_PURCHASE)
  amount      Int
  credits     Int
  description String?         @db.VarChar(500)
  status      String          @default("pending") @db.VarChar(50)
  payosRef    String?         @map("payos_ref") @db.VarChar(255)
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@map("transactions")
}

// ─── AI Form Check ───────────────────────────────────────────────────────────

model TrainingSession {
  id           Int              @id @default(autoincrement())
  userId       Int              @map("user_id")
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId   Int?             @map("exercise_id")
  exercise     Exercise?        @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  programId    Int?             @map("program_id")
  program      TrainingProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  status       String           @default("pending") @db.VarChar(50)
  jobId        String?          @map("job_id") @db.VarChar(255)
  score        Float?
  payload      Json?
  result       Json?
  trainerNotes String?          @map("trainer_notes")
  createdAt    DateTime         @default(now()) @map("created_at")

  challengeSessions ChallengeSession[]

  @@index([userId])
  @@index([score])
  @@index([status])
  @@index([programId])
  @@index([exerciseId])
  @@map("training_sessions")
}

// Requires pgvector extension: CREATE EXTENSION IF NOT EXISTS vector;
model Exercise {
  id              Int         @id @default(autoincrement())
  name            String      @db.VarChar(255)
  description     String?
  category        String?     @db.VarChar(100)
  difficulty      Difficulty?
  videoUrl        String?     @map("video_url") @db.VarChar(500)
  musclesTargeted Json?       @map("muscles_targeted")
  creatorId       Int?        @map("creator_id")
  creator         User?       @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime    @default(now()) @map("created_at")

  sessions         TrainingSession[]
  programExercises ProgramExercise[]
  challenges       Challenge[]

  @@index([category])
  @@index([creatorId])
  @@map("exercises")
}

// ─── Marketplace & RAG ───────────────────────────────────────────────────────

model TrainingProgram {
  id             Int           @id @default(autoincrement())
  trainerId      Int           @map("trainer_id")
  trainer        User          @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  title          String        @db.VarChar(255)
  description    String?
  thumbnailUrl   String?       @map("thumbnail_url")
  price          Int           @default(0)
  durationWeeks  Int?          @map("duration_weeks")
  isAiGenerated  Boolean       @default(false) @map("is_ai_generated")
  status         ProgramStatus @default(DRAFT)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  programExercises ProgramExercise[]
  userPrograms     UserProgram[]
  sessions         TrainingSession[]

  @@index([trainerId])
  @@index([status])
  @@map("training_programs")
}

model ProgramExercise {
  id              Int             @id @default(autoincrement())
  programId       Int             @map("program_id")
  program         TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  exerciseId      Int             @map("exercise_id")
  exercise        Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  dayNumber       Int             @map("day_number")
  orderInDay      Int             @map("order_in_day")
  sets            Int?
  reps            Int?
  durationSeconds Int?            @map("duration_seconds")
  notes           String?

  @@unique([programId, dayNumber, orderInDay])
  @@index([programId])
  @@index([exerciseId])
  @@map("program_exercises")
}

model UserProgram {
  id          Int             @id @default(autoincrement())
  userId      Int             @map("user_id")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId   Int             @map("program_id")
  program     TrainingProgram @relation(fields: [programId], references: [id], onDelete: Restrict)
  amountPaid  Int             @map("amount_paid")
  purchasedAt DateTime        @default(now()) @map("purchased_at")

  @@unique([userId, programId])
  @@index([userId])
  @@index([programId])
  @@map("user_programs")
}

// ─── Gamification ────────────────────────────────────────────────────────────

model Challenge {
  id             Int       @id @default(autoincrement())
  title          String    @db.VarChar(255)
  description    String?
  exerciseId     Int       @map("exercise_id")
  exercise       Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  targetReps     Int?      @map("target_reps")
  targetScore    Float?    @map("target_score")
  rewardCredits  Int       @map("reward_credits")
  startAt        DateTime  @map("start_at")
  endAt          DateTime  @map("end_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  sessions ChallengeSession[]

  @@index([exerciseId])
  @@index([startAt, endAt])
  @@map("challenges")
}

model ChallengeSession {
  id                Int              @id @default(autoincrement())
  userId            Int              @map("user_id")
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId       Int              @map("challenge_id")
  challenge         Challenge        @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  trainingSessionId Int?             @map("training_session_id")
  trainingSession   TrainingSession? @relation(fields: [trainingSessionId], references: [id], onDelete: SetNull)
  achievedReps      Int?             @map("achieved_reps")
  achievedScore     Float?           @map("achieved_score")
  status            ChallengeStatus  @default(PENDING)
  completedAt       DateTime?        @map("completed_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
  @@index([trainingSessionId])
  @@map("challenge_sessions")
}

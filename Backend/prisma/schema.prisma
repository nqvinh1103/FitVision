generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  TRAINEE
  TRAINER
  ADMIN
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum TransactionType {
  CREDIT_PURCHASE
  PROGRAM_PURCHASE
  ONEONONE_UPGRADE
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ProgramStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProgramType {
  TEMPLATE // Marketplace — bán cho nhiều Trainee
  ADAPTIVE // 1-on-1 — generate riêng cho 1 Trainee cụ thể
}

enum ChallengeStatus {
  PENDING
  PASSED
  FAILED
}

enum Goal {
  STRENGTH
  FAT_LOSS
  ENDURANCE
  GENERAL_FITNESS
}

enum TrainerTraineeSource {
  INVITE             // Trainer gửi invite link cho PT client offline
  MARKETPLACE_UPGRADE // Trainee mua program → upgrade lên 1-on-1
}

enum TrainerTraineeStatus {
  PENDING // chờ bên kia confirm
  ACTIVE  // đang trong quan hệ
  ENDED   // đã kết thúc
}

enum DigestStatus {
  PENDING_AUTO     // mới tạo, đang xử lý auto-apply MINOR
  AUTO_APPLIED     // chỉ có MINOR, đã apply hết, Trainer chỉ cần xem
  PENDING_TRAINER  // có MAJOR adjustments, cần Trainer duyệt
  TRAINER_DONE     // Trainer đã approve/modify xong
}

enum NotificationType {
  RED_GROUP_ALERT       // Trainer: "Trainee X sai form 3 lần liên tiếp"
  WEEKLY_DIGEST_AUTO    // Trainer: "Đã tự điều chỉnh N bài cho Trainee X"
  WEEKLY_DIGEST_PENDING // Trainer: "Cần duyệt điều chỉnh cho Trainee X"
  PROGRAM_ADJUSTED      // Trainee: "Lịch tập tuần mới đã được cập nhật"
  TRAINER_NOTE          // Trainee: "Trainer để lại ghi chú cho buổi tập của bạn"
  CHALLENGE_RESULT      // Trainee: "Bạn đã vượt qua/thất bại challenge"
  INVITE_RECEIVED       // Trainee: "Trainer X mời bạn vào chương trình"
  UPGRADE_CONFIRMED     // Trainee: "Trainer X đã xác nhận nâng cấp 1-on-1"
}

// ─── Auth & Identity ─────────────────────────────────────────────────────────

model User {
  id              Int              @id @default(autoincrement())
  email           String           @unique @db.VarChar(255)
  passwordHash    String           @map("password_hash")
  role            Role             @default(TRAINEE)
  aiCredits       Int              @default(2) @map("ai_credits")
  name            String?          @db.VarChar(255)
  avatarUrl       String?          @map("avatar_url")
  experienceLevel ExperienceLevel? @map("experience_level")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  refreshTokens     RefreshToken[]
  sessions          TrainingSession[]
  transactions      Transaction[]
  exercises         Exercise[]
  programs          TrainingProgram[]
  userPrograms      UserProgram[]
  challengeSessions ChallengeSession[]

  // New relations
  profile           UserProfile?
  trainerRelations  TrainerTrainee[]      @relation("TrainerRelations")
  traineeRelations  TrainerTrainee[]      @relation("TraineeRelations")
  programProgress   UserProgramProgress[]
  trainerDigests    WeeklyDigest[]        @relation("DigestTrainer")
  traineeDigests    WeeklyDigest[]        @relation("DigestTrainee")
  notifications     Notification[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model RegistrationOtp {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  otpHash      String   @map("otp_hash")
  passwordHash String   @map("password_hash")
  role         Role     @default(TRAINEE)
  name         String?  @db.VarChar(255)
  attempts     Int      @default(0)
  expiresAt    DateTime @map("expires_at")
  lastSentAt   DateTime @default(now()) @map("last_sent_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("registration_otps")
}

model PasswordResetOtp {
  id         Int      @id @default(autoincrement())
  email      String   @unique @db.VarChar(255)
  otpHash    String   @map("otp_hash")
  attempts   Int      @default(0)
  expiresAt  DateTime @map("expires_at")
  lastSentAt DateTime @default(now()) @map("last_sent_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("password_reset_otps")
}

// ─── User Profile ─────────────────────────────────────────────────────────────

model UserProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Trainee fields
  goal            Goal?    @default(GENERAL_FITNESS)
  hasPullUpBar    Boolean  @default(false) @map("has_pull_up_bar")
  hasParallelBars Boolean  @default(false) @map("has_parallel_bars")
  injuries        Json?    // ["lower_back", "knee"]

  // Trainer fields
  trainerBio         String? @db.Text @map("trainer_bio")
  trainerSpeciality  String? @db.VarChar(255) @map("trainer_speciality")
  trainer1on1Price   Int?    @map("trainer_1on1_price") // VNĐ — Trainer tự đặt giá

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

// ─── Trainer ↔ Trainee Relationship ──────────────────────────────────────────

model TrainerTrainee {
  id         Int                  @id @default(autoincrement())
  trainerId  Int                  @map("trainer_id")
  traineeId  Int                  @map("trainee_id")
  trainer    User                 @relation("TrainerRelations", fields: [trainerId], references: [id], onDelete: Cascade)
  trainee    User                 @relation("TraineeRelations", fields: [traineeId], references: [id], onDelete: Cascade)
  source     TrainerTraineeSource
  status     TrainerTraineeStatus @default(PENDING)
  inviteToken String?             @unique @map("invite_token") @db.VarChar(255)
  invitedAt  DateTime             @default(now()) @map("invited_at")
  activatedAt DateTime?           @map("activated_at")

  @@unique([trainerId, traineeId])
  @@index([trainerId])
  @@index([traineeId])
  @@map("trainer_trainees")
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Transaction {
  id          Int             @id @default(autoincrement())
  userId      Int             @map("user_id")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType @default(CREDIT_PURCHASE)
  amount      Int
  credits     Int
  description String?         @db.VarChar(500)
  status      String          @default("pending") @db.VarChar(50)
  payosRef    String?         @map("payos_ref") @db.VarChar(255)
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@map("transactions")
}

// ─── AI Form Check ───────────────────────────────────────────────────────────

model TrainingSession {
  id           Int              @id @default(autoincrement())
  userId       Int              @map("user_id")
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId   Int?             @map("exercise_id")
  exercise     Exercise?        @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  programId    Int?             @map("program_id")
  program      TrainingProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  status       String           @default("pending") @db.VarChar(50)
  jobId        String?          @map("job_id") @db.VarChar(255)
  score        Float?
  payload      Json?
  result       Json?
  trainerNotes String?          @map("trainer_notes")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@index([userId])
  @@index([score])
  @@index([status])
  @@index([programId])
  @@index([exerciseId])
  @@map("training_sessions")
}

model Exercise {
  id              Int         @id @default(autoincrement())
  name            String      @db.VarChar(255)
  description     String?
  category        String?     @db.VarChar(100)
  difficulty      Difficulty?
  videoUrl        String?     @map("video_url") @db.VarChar(500)
  musclesTargeted Json?       @map("muscles_targeted")
  creatorId       Int?        @map("creator_id")
  creator         User?       @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  createdAt       DateTime    @default(now()) @map("created_at")

  // embedding vector(768) — managed via manual migration, not Prisma

  sessions         TrainingSession[]
  programExercises ProgramExercise[]
  challenges       Challenge[]

  @@index([category])
  @@index([creatorId])
  @@map("exercises")
}

// ─── Marketplace & RAG ───────────────────────────────────────────────────────

model TrainingProgram {
  id               Int           @id @default(autoincrement())
  trainerId        Int?          @map("trainer_id") // nullable — NULL khi isSystemTemplate
  trainer          User?         @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  title            String        @db.VarChar(255)
  description      String?
  thumbnailUrl     String?       @map("thumbnail_url")
  price            Int           @default(0)
  durationWeeks    Int?          @map("duration_weeks")
  sessionsPerWeek  Int?          @map("sessions_per_week")
  isAiGenerated    Boolean       @default(false) @map("is_ai_generated")
  isSystemTemplate Boolean       @default(false) @map("is_system_template")
  programType      ProgramType   @default(TEMPLATE) @map("program_type")
  status           ProgramStatus @default(DRAFT)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  programExercises ProgramExercise[]
  userPrograms     UserProgram[]
  sessions         TrainingSession[]
  progress         UserProgramProgress[]
  digests          WeeklyDigest[]

  @@index([trainerId])
  @@index([status])
  @@index([programType])
  @@index([isSystemTemplate])
  @@map("training_programs")
}

model ProgramExercise {
  id              Int             @id @default(autoincrement())
  programId       Int             @map("program_id")
  program         TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  exerciseId      Int             @map("exercise_id")
  exercise        Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  dayNumber       Int             @map("day_number") // sequential: 1,2,3... trong chu kỳ tuần
  orderInDay      Int             @map("order_in_day")
  sets            Int?
  reps            Int?
  durationSeconds Int?            @map("duration_seconds")
  progressions    Json?           // [{"week":1,"sets":3,"reps":8}, {"week":2,"sets":3,"reps":10}]
  notes           String?         @db.Text // ghi chú hướng dẫn của Trainer cho Trainee

  @@unique([programId, dayNumber, orderInDay])
  @@index([programId])
  @@index([exerciseId])
  @@map("program_exercises")
}

model UserProgram {
  id          Int             @id @default(autoincrement())
  userId      Int             @map("user_id")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId   Int             @map("program_id")
  program     TrainingProgram @relation(fields: [programId], references: [id], onDelete: Restrict)
  amountPaid  Int             @map("amount_paid")
  purchasedAt DateTime        @default(now()) @map("purchased_at")

  @@unique([userId, programId])
  @@index([userId])
  @@index([programId])
  @@map("user_programs")
}

// ─── Program Progress ─────────────────────────────────────────────────────────

model UserProgramProgress {
  id            Int             @id @default(autoincrement())
  userId        Int             @map("user_id")
  programId     Int             @map("program_id")
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  program       TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  currentWeek   Int      @default(1) @map("current_week")
  currentDay    Int      @default(1) @map("current_day") // day_number trong chu kỳ tuần
  startedAt     DateTime @default(now()) @map("started_at")
  lastSessionAt DateTime? @map("last_session_at")
  weekStartedAt DateTime @default(now()) @map("week_started_at") // để tính 7 ngày calendar-based

  @@unique([userId, programId])
  @@index([userId])
  @@index([programId])
  @@map("user_program_progress")
}

// ─── Adaptive Program — Weekly Digest ────────────────────────────────────────

model WeeklyDigest {
  id          Int             @id @default(autoincrement())
  trainerId   Int             @map("trainer_id")
  traineeId   Int             @map("trainee_id")
  programId   Int             @map("program_id")
  trainer     User            @relation("DigestTrainer", fields: [trainerId], references: [id])
  trainee     User            @relation("DigestTrainee", fields: [traineeId], references: [id])
  program     TrainingProgram @relation(fields: [programId], references: [id])

  weekNumber        Int          @map("week_number")
  avgFormScores     Json         @map("avg_form_scores") // {"exercise_id": avg_score}
  aiAnalysis        String       @db.Text @map("ai_analysis") // tóm tắt cho Trainer đọc
  adjustments       Json         // [{exercise_id, type, field, old_value, new_value, reason, applied}]
  status            DigestStatus @default(PENDING_AUTO)
  trainerReviewedAt DateTime?    @map("trainer_reviewed_at")
  createdAt         DateTime     @default(now()) @map("created_at")

  @@index([trainerId, status])
  @@index([traineeId, programId])
  @@map("weekly_digests")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  payload   Json
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@map("notifications")
}

// ─── Gamification ────────────────────────────────────────────────────────────

model Challenge {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar(255)
  description   String?
  exerciseId    Int       @map("exercise_id")
  exercise      Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  targetReps    Int?      @map("target_reps")
  targetScore   Float?    @map("target_score")
  rewardCredits Int       @map("reward_credits")
  startAt       DateTime  @map("start_at")
  endAt         DateTime  @map("end_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  sessions ChallengeSession[]

  @@index([exerciseId])
  @@index([startAt, endAt])
  @@map("challenges")
}

model ChallengeSession {
  id           Int             @id @default(autoincrement())
  userId       Int             @map("user_id")
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId  Int             @map("challenge_id")
  challenge    Challenge       @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  achievedReps Int?            @map("achieved_reps")
  achievedScore Float?         @map("achieved_score")
  status       ChallengeStatus @default(PENDING)
  completedAt  DateTime?       @map("completed_at")
  createdAt    DateTime        @default(now()) @map("created_at")

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
  @@map("challenge_sessions")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  TRAINEE
  TRAINER
  ADMIN
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum TransactionType {
  CREDIT_PURCHASE
  PROGRAM_PURCHASE
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ─── Auth & Identity ─────────────────────────────────────────────────────────

model User {
  id              Int              @id @default(autoincrement())
  email           String           @unique @db.VarChar(255)
  passwordHash    String           @map("password_hash")
  role            Role             @default(TRAINEE)
  aiCredits       Int              @default(2) @map("ai_credits")
  name            String?          @db.VarChar(255)
  avatarUrl       String?          @map("avatar_url")
  experienceLevel ExperienceLevel? @map("experience_level")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  sessions      TrainingSession[]
  transactions  Transaction[]
  exercises     Exercise[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Transaction {
  id          Int             @id @default(autoincrement())
  userId      Int             @map("user_id")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType @default(CREDIT_PURCHASE)
  amount      Int
  credits     Int
  description String?         @db.VarChar(500)
  status      String          @default("pending") @db.VarChar(50)
  payosRef    String?         @map("payos_ref") @db.VarChar(255)
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([userId])
  @@map("transactions")
}

// ─── AI Form Check ───────────────────────────────────────────────────────────

model TrainingSession {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId   Int?      @map("exercise_id")
  exercise     Exercise? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  status       String    @default("pending") @db.VarChar(50)
  jobId        String?   @map("job_id") @db.VarChar(255)
  score        Float?
  payload      Json?
  result       Json?
  trainerNotes String?   @map("trainer_notes")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([score])
  @@index([status])
  @@map("training_sessions")
}

// Requires pgvector extension: CREATE EXTENSION IF NOT EXISTS vector;
model Exercise {
  id              Int         @id @default(autoincrement())
  name            String      @db.VarChar(255)
  description     String?
  category        String?     @db.VarChar(100)
  difficulty      Difficulty?
  videoUrl        String?     @map("video_url") @db.VarChar(500)
  musclesTargeted Json?       @map("muscles_targeted")
  creatorId       Int?        @map("creator_id")
  creator         User?       @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime    @default(now()) @map("created_at")

  sessions TrainingSession[]

  @@index([category])
  @@index([creatorId])
  @@map("exercises")
}
